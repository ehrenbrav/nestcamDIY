# NestCam sample environment file
#
# After editing this file, restart the service:
#   sudo systemctl restart nestcam.service
#
# Notes:
# - Lines starting with # are comments.
# - Leave a setting commented out to use the daemon's built-in default.
# - For night image-quality experiments, change one variable at a time.

# -------------------- Live view / web server --------------------

# Address to bind the live MJPEG server to.
# 0.0.0.0 = listen on all interfaces.
LIVE_BIND=0.0.0.0

# TCP port for the web UI and MJPEG stream.
# Typical values: 8080, 8081.
LIVE_PORT=8080

# Optional HTTP BasicAuth for the live stream.
# Leave AUTH_ENABLED commented out or set to 0 for no login prompt.
# Set AUTH_ENABLED=1 and set both LIVE_USER and LIVE_PASS to enable auth.
# AUTH_ENABLED=1
# LIVE_USER=nestcam
# LIVE_PASS=change-me

# -------------------- Recording / storage --------------------

# Where recordings are stored.
RECORDINGS_ROOT=/var/lib/nestcam/recordings

# Enable recording to disk.
# 1 = record motion-triggered clips
# 0 = live view only, no saved recordings
RECORDING_ENABLED=1

# Minimum free space required before starting a new recording.
# If free space drops below this, recording will be refused and retention
# may run if configured elsewhere.
# Reasonable values to try: 1.0, 2.0, 4.0
MIN_FREE_GB=2.0

# -------------------- Camera image tuning --------------------

# Target camera frame rate.
# Lower values allow longer exposures in low light.
# Good values to experiment with for IR-only night scenes: 5, 10, 15.
# General daytime value: 20.
FPS=20

# Auto exposure / auto gain control.
# 1 = automatic exposure and gain
# 0 = manual exposure/gain using EXPOSURE_TIME and ANALOGUE_GAIN below
# Start with 1 unless you are deliberately tuning night IR performance.
AE_ENABLE=1

# Manual exposure time in microseconds.
# Only use this when AE_ENABLE=0.
# Longer exposure = brighter image, but more motion blur.
# Sensible values to experiment with:
#   50000   = 50 ms
#   80000   = 80 ms
#   100000  = 100 ms
#   150000  = 150 ms
# Keep this at or below the frame interval implied by FPS.
# Examples:
#   FPS=10  -> frame interval is about 100000 us
#   FPS=5   -> frame interval is about 200000 us
# EXPOSURE_TIME=80000

# Manual analogue gain.
# Only use this when AE_ENABLE=0.
# Higher gain brightens the image but also increases noise.
# Start low and increase only if the image is still too dark.
# The values depend on the camera:
# Stop the nestcam service and run:
#   python3 -c 'from picamera2 import Picamera2; p = Picamera2(); print("AnalogueGain:", p.camera_controls["AnalogueGain"])'
# ANALOGUE_GAIN=2.0

# Image saturation.
# 1.0 is normal color.
# 0.0 produces grayscale, which is often preferable for IR-only night scenes.
# Good values to experiment with:
#   1.0 = normal color
#   0.5 = reduced color
#   0.0 = grayscale
# SATURATION=0.0

# -------------------- Day / night mode and IR --------------------

# Local clock times that define "night mode".
# The daemon checks these only when the camera starts. It does not switch
# modes while the camera is already running, even if the clock crosses one
# of these boundaries later.
#
# Typical use is a window that spans midnight, such as 20:00 to 06:00.
# In that case, night mode is active from 8:00 PM until 6:00 AM.
# If both values are the same, night mode is treated as disabled.
NIGHT_MODE_START=20:00
NIGHT_MODE_END=06:00

# GPIO pin controlling the external IR LEDs.
IR_GPIO=18

# Whether the IR LED driver is active-high.
# 1 = GPIO high turns lights on
# 0 = GPIO low turns lights on
IR_ACTIVE_HIGH=1

# IR LED brightness from 0.0 to 1.0.
# These LEDs are only enabled while the camera is active and the current
# camera session was started during night mode.
# Good values to experiment with: 0.25, 0.5, 0.75, 1.0
IR_BRIGHTNESS=1.0

# PWM frequency in Hz for dimming the IR LEDs.
# Typical values: 200 to 1000.
# 500 is a sensible default.
IR_PWM_FREQUENCY=500

# Optional IR-cut filter control for cameras that support switching between
# day mode and night mode, such as the Waveshare IMX462 IR-cut camera.
# Leave IR_CUT_GPIO commented out if your camera does not support this.
# If IR_CUT_GPIO is set, IR_CUT_ENABLED defaults to on unless you override it.
# IR_CUT_GPIO=24

# Optional explicit on/off override for IR-cut control.
# 1 = enable IR-cut switching
# 0 = disable IR-cut switching even if IR_CUT_GPIO is set
# IR_CUT_ENABLED=1

# Whether the IR-cut control pin should be driven high for day mode.
# If day and night are reversed on your hardware, flip this to 0.
IR_CUT_DAY_HIGH=1

# -------------------- Motion detection --------------------

# GPIO pin for the motion sensor (BCM numbering).
# BCM GPIO 23 corresponds to physical pin 16 per the README.
MOTION_GPIO_PIN=23

# Whether the motion sensor output is active-high.
# 1 = motion detected when GPIO reads high
# 0 = motion detected when GPIO reads low
# AM312 PIR sensor is active-high.
# With gpiozero, this must match the pull setting unless MOTION_PULL=none:
#   MOTION_PULL=down -> MOTION_ACTIVE_HIGH=1
#   MOTION_PULL=up   -> MOTION_ACTIVE_HIGH=0
MOTION_ACTIVE_HIGH=1

# Internal pull-up/pull-down resistor for motion sensor GPIO.
# Options: up, down, none
# For the AM312 on this project, use "down" so the Pi input does not float
# if the sensor output is disconnected or weakly driven.
# If you need opposite polarity from the built-in pull, set MOTION_PULL=none
# and provide the appropriate external biasing instead.
MOTION_PULL=down

# Motion sampling frequency in Hz.
# Higher values check the PIR more often.
# These debounce settings below are measured in samples, so the effective
# debounce time is roughly samples / SAMPLE_HZ.
# Example: 4 samples at 8 Hz is about 0.5 seconds.
SAMPLE_HZ=8

# Number of consecutive active samples required before motion is treated as real.
# Increase this to reduce false triggers.
# Reasonable values to try: 4, 5, 6
MOTION_TRIGGER_CONSECUTIVE_SAMPLES=4

# Number of consecutive inactive samples required before motion is treated as cleared.
# Keep this lower than the trigger threshold so real motion does not flap off too easily.
# Reasonable values to try: 2, 3
MOTION_CLEAR_CONSECUTIVE_SAMPLES=2

# Minimum recording length in seconds.
# Even brief motion events will record for at least this long.
MIN_CLIP_SECONDS=8

# Cooldown period after motion stops before ending recording.
# Prevents choppy recordings from intermittent motion.
MOTION_COOLDOWN_SECONDS=8

# Grace period after startup before motion detection begins.
# Allows PIR sensor to stabilize after power-on.
MOTION_STARTUP_GRACE_SECONDS=20
